# ============================================================
# hive-api — Variables de entorno requeridas
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a git — solo este .env.example.
# ============================================================

# -----------------------------------------------------------------
# Base de datos PostgreSQL
# Formato: postgres://usuario:contraseña@host:puerto/nombre_db
# En Docker Compose el host es el nombre del servicio ("db")
# -----------------------------------------------------------------
DATABASE_URL=postgres://hive:changeme@localhost:5432/hive

# -----------------------------------------------------------------
# Clave secreta para firmar los tokens JWT
# MÍNIMO 32 caracteres. Genera una con:
#   openssl rand -base64 32
# Si es menor de 32 caracteres, el servidor no arrancará.
# -----------------------------------------------------------------
JWT_SECRET=cambia-esto-por-una-clave-secreta-de-al-menos-32-chars

# -----------------------------------------------------------------
# Puerto en el que escucha el servidor HTTP
# Por defecto: 8080
# -----------------------------------------------------------------
PORT=8080

# -----------------------------------------------------------------
# Modo de Gin (el framework HTTP)
# "debug"   → logs detallados, útil en desarrollo
# "release" → silencioso, para producción
# -----------------------------------------------------------------
GIN_MODE=debug

# -----------------------------------------------------------------
# Base de datos para los tests de integración (NO la de producción)
# Los tests crean y destruyen datos reales en esta DB.
# Debe ser una DB separada, nunca la misma que DATABASE_URL.
# -----------------------------------------------------------------
TEST_DATABASE_URL=postgres://hive:changeme@localhost:5432/hive_test
